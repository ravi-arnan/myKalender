<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MyKalender" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/canvas</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/canvas</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.MyKalender.Alarm" parent="android:Theme.Material.NoActionBar.Fullscreen">
        <item name="android:windowBackground">@color/surface_dark</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
