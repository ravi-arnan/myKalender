# Firebase Web SDK config — ambil dari Firebase Console → Project Settings → SDK setup and configuration → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# AI Schedule Generator proxy (Cloudflare Worker, see /worker). The GitHub
# Models PAT lives server-side as a worker secret, NOT here. This is just the
# public worker URL, e.g. https://mykalender-ai.<subdomain>.workers.dev
VITE_AI_PROXY_URL=
